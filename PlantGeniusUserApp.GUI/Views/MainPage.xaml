<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlantGeniusUserApp.GUI.Views.MainPage">


    <Grid>
        <!-- Add background picture-->
        <Image Source="..\Images\background_picture.jpg" Aspect="AspectFill"/>

        <VerticalStackLayout Spacing="25" Padding="30">

        <Label Text="Willkommen bei PlantGenius!"
               FontSize="Large"
               HorizontalOptions="Center" />

        <Label Text="Dein persönlicher Assistent für die Pflanzenpflege."
               HorizontalOptions="Center" />

        <Frame Padding="15" CornerRadius="10">
            <Label Text="3 Pflanzen sollten gewässert werden"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
        </Frame>


        </VerticalStackLayout>
    </Grid>

</ContentPage>