<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlantGeniusUserApp.GUI.Views.MainPage">


    <Grid>
        <!-- Add background picture-->
        <!-- Background image -->
        <Image Grid.Row="0" Grid.Column="0" Source="background_picture.jpg" Aspect="AspectFill"/>
        <VerticalStackLayout Spacing="25" Padding="30" >

            <Frame Padding="0,10" CornerRadius="10"  Background ="{StaticResource Secondary}" >
                <StackLayout>
                    <Label Text="Willkommen bei PlantGenius!" 
                    FontSize="Large"
                    HorizontalOptions="Center" 
                    FontAttributes="Bold"/>

                <Label Text="Dein persönlicher Assistent für die Pflanzenpflege." Margin="0,10,0,0"
                    HorizontalOptions="Center" />
                </StackLayout>
            </Frame>
        
            <Frame Padding="15" CornerRadius="10"  Background ="{StaticResource Secondary}" >
                <Label Text="{Binding Count, StringFormat='{0} Pflanzen sollten gewässert werden'}"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                  />
            </Frame>


        </VerticalStackLayout>
    </Grid>

</ContentPage>