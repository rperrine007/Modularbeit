<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlantGeniusUser.GUI.MainPage">


<VerticalStackLayout Spacing="25" Padding="30">

        <Label Text="Willkommen PlantGenius!"
               FontSize="Large"
               HorizontalOptions="Center" />

        <Label Text="Dein persönlicher Assistent für die Pflanzenpflege."
               HorizontalOptions="Center" />

        <Frame Padding="15" CornerRadius="10">
            <Label Text="3 Pflanzen sollten gewässert werden"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
        </Frame>

        <Button Text="Anzeige aller Pflanzen"
                Command="{Binding NavigateToPlantPageCommand}" />


        <Button Text="Einstellungen"
                Command="{Binding NavigateToSettingsPageCommand}" />

    </VerticalStackLayout>

</ContentPage>