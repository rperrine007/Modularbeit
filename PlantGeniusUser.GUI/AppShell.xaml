<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:PlantGeniusUser.GUI.Views"
       x:Class="PlantGeniusUser.GUI.AppShell">

    <TabBar>
        <Tab Title="Main" Icon="home_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Plants" Icon="flower_plant_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:PlantPage}" />
        </Tab>
        <Tab Title="Settings" Icon="settings_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:SettingPage}" />
        </Tab>
    </TabBar>
</Shell>

