<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:PlantGeniusUser.GUI.Views"
       x:Class="PlantGeniusUser.GUI.AppShell"
       BackgroundColor="LightBlue">

    <ShellContent Title="Home" ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />
    <ShellContent Title="PlantPage" ContentTemplate="{DataTemplate views:PlantPage}" Route="PlantPage" />
    <ShellContent Title="SettingPage" ContentTemplate="{DataTemplate views:SettingPage}" Route="SettingPage" />
    <ShellContent Title="NavPage" ContentTemplate="{DataTemplate views:NavPage}" Route="NavPage" />

   
</Shell>
